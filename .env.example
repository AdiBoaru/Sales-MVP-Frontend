# ── Supabase (read-only catalog) ─────────────────────────────────────────────
# Public values, gated by RLS (public-read on products / product_images).
VITE_SUPABASE_URL=https://xfczucwqntefethxxien.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# ── izi chat bot ("Aria") ────────────────────────────────────────────────────
# Keep VITE_CHAT_API_BASE EMPTY in dev so requests go through the Vite /web proxy
# (which spoofs Origin to satisfy the bot's CORS). Prod injects the real value via
# the GitHub secret VITE_CHAT_API_BASE (= https://bot.nativextech.com) at build time.
VITE_CHAT_API_BASE=
VITE_CHAT_PUBLIC_TOKEN=pub_your_public_token

# ⚠️ Never put service_role keys or DB passwords in VITE_* — they end up in the browser bundle.
