[
  {
    "case": "text_empty",
    "note": "Empty reply (silent handoff) -> graceful fallback, no blank bubble, no crash.",
    "payload": { "content": "", "products": [], "suggestions": [] },
    "assert": { "emptyFallback": true, "noBubble": true, "productCards": 0, "comparisonTable": false }
  },
  {
    "case": "text_clarify",
    "note": "One text bubble, no cards/chips.",
    "payload": { "content": "Ce tip de ten ai — gras, mixt sau uscat?", "products": [], "suggestions": [] },
    "assert": { "textPresent": ["Ce tip de ten ai — gras, mixt sau uscat?"], "productCards": 0, "comparisonTable": false }
  },
  {
    "case": "simple_products",
    "note": "Bare card: name+price+image+link, content above.",
    "payload": {
      "content": "Uite produsele 👇",
      "suggestions": [],
      "products": [{ "product_id": "p1", "name": "Produs A", "price": 61.99, "url": "https://x/p1", "image_url": "https://x/a.jpg" }]
    },
    "assert": { "textPresent": ["Uite produsele", "Produs A", "Lei"], "productCards": 1, "linkHrefs": ["https://x/p1"] }
  },
  {
    "case": "rich_full",
    "note": "list_price struck + derived discount, badge, rating(count), reason, 6 chips, 2-paragraph content.",
    "payload": {
      "content": "Pentru ten uscat, uite ce merge.\n\nCând alegi, uită-te la textură și la confort.",
      "suggestions": ["Una mai ieftină", "Ceva fără parfum", "Compară primele două", "Pentru ten gras", "Cu SPF", "Trimite-mi linkul"],
      "products": [
        { "product_id": "p1", "name": "Crema A", "price": 58.99, "list_price": 79.99, "rating": 4.8, "review_count": 120, "reason": "pentru ten uscat — hidratează intens", "badge": "Top Favorit", "image_url": "https://x/a.jpg", "url": "https://x/p1" },
        { "product_id": "p2", "name": "Crema B", "price": 42.0, "rating": 4.6, "review_count": 54, "reason": "opțiune mai accesibilă", "badge": "Super Preț", "image_url": "https://x/b.jpg", "url": "https://x/p2" }
      ]
    },
    "assert": {
      "textPresent": ["Pentru ten uscat, uite ce merge.", "Când alegi, uită-te la textură și la confort.", "Crema A", "Crema B", "Top Favorit", "Super Preț", "4.8", "(120)", "pentru ten uscat — hidratează intens", "opțiune mai accesibilă", "79,99", "Una mai ieftină", "Trimite-mi linkul"],
      "productCards": 2,
      "discountBadge": true,
      "lineBreak": true
    }
  },
  {
    "case": "rich_card_minimal",
    "note": "Only id/name/price -> no rating/badge/reason/image/link, no 'undefined'/'null'.",
    "payload": { "content": "O singură potrivire:", "suggestions": [], "products": [{ "product_id": "p1", "name": "Produs minimal", "price": 30.0 }] },
    "assert": { "textPresent": ["O singură potrivire:", "Produs minimal", "Lei"], "productCards": 1, "linkHrefs": [] }
  },
  {
    "case": "rich_pick_in_content",
    "note": "'👉 Recomandarea mea' arrives inside content as normal text; disclaimer visible.",
    "payload": {
      "content": "Pentru ten uscat, uite opțiunile.\n\n👉 Recomandarea mea: Crema A — pentru confort imediat.\n\nFuncționez cu inteligență artificială, așa că pot greși uneori.",
      "suggestions": [],
      "products": [{ "product_id": "p1", "name": "Crema A", "price": 58.99 }]
    },
    "assert": { "textPresent": ["👉 Recomandarea mea: Crema A", "Funcționez cu inteligență artificială"], "productCards": 1 }
  },
  {
    "case": "comparison_2col_nulls",
    "note": "Renders a TABLE not cards; header = columns; null cell -> '—'; chips present.",
    "payload": {
      "content": "Iată diferențele principale.",
      "suggestions": ["Adaugă Crema A", "Adaugă Crema B", "Ceva mai ieftin"],
      "products": [{ "product_id": "p1", "name": "Crema A", "price": 58.99, "image_url": "https://x/a.jpg" }, { "product_id": "p2", "name": "Crema B", "price": 88.99 }],
      "comparison": {
        "columns": [{ "product_id": "p1", "name": "Crema A", "price": 58.99, "rating": 4.8, "image_url": "https://x/a.jpg" }, { "product_id": "p2", "name": "Crema B", "price": 88.99, "rating": 4.6 }],
        "rows": [
          { "label": "Preț", "values": ["58.99 lei", "88.99 lei"] },
          { "label": "Rating", "values": ["4.8★", "4.6★"] },
          { "label": "Disponibilitate", "values": ["În stoc", "Stoc limitat"] },
          { "label": "Avantaje", "values": ["hidratează intens; fără parfum", "bogată"] },
          { "label": "De luat în calcul", "values": ["tub mic", null] },
          { "label": "Brand", "values": ["BrandX", "BrandY"] }
        ]
      }
    },
    "assert": { "comparisonTable": true, "columnHeaders": 3, "dash": true, "productCards": 0, "textPresent": ["Iată diferențele principale.", "Crema A", "Crema B", "58,99", "Adaugă Crema A"] }
  },
  {
    "case": "comparison_3col_sparse",
    "note": "3 columns, only 2 rows, valid.",
    "payload": {
      "content": "Comparație.",
      "suggestions": [],
      "comparison": {
        "columns": [{ "product_id": "p1", "name": "A", "price": 10 }, { "product_id": "p2", "name": "B", "price": 20 }, { "product_id": "p3", "name": "C", "price": 30 }],
        "rows": [{ "label": "Preț", "values": ["10 lei", "20 lei", "30 lei"] }, { "label": "Rating", "values": ["4.5★", "4.7★", "4.2★"] }]
      },
      "products": [{ "product_id": "p1", "name": "A", "price": 10 }, { "product_id": "p2", "name": "B", "price": 20 }, { "product_id": "p3", "name": "C", "price": 30 }]
    },
    "assert": { "comparisonTable": true, "columnHeaders": 4, "productCards": 0, "textPresent": ["Preț", "Rating"] }
  },
  {
    "case": "comparison_listprice",
    "note": "Column with list_price -> struck original next to price.",
    "payload": {
      "content": "Comparație cu reduceri.",
      "suggestions": [],
      "comparison": {
        "columns": [{ "product_id": "p1", "name": "A", "price": 50, "list_price": 80 }, { "product_id": "p2", "name": "B", "price": 60 }],
        "rows": [{ "label": "Preț", "values": ["50.00 lei (de la 80.00)", "60.00 lei"] }]
      },
      "products": [{ "product_id": "p1", "name": "A", "price": 50, "list_price": 80 }, { "product_id": "p2", "name": "B", "price": 60 }]
    },
    "assert": { "comparisonTable": true, "productCards": 0, "textPresent": ["80,00", "de la 80.00"] }
  },
  {
    "case": "comparison_longnames",
    "note": "Long names render in full (no JS truncation); mobile stacks via CSS.",
    "payload": {
      "content": "Comparație nume lungi.",
      "suggestions": [],
      "comparison": {
        "columns": [{ "product_id": "p1", "name": "Fond de ten rezistent la transfer cu acoperire medie-mare 30ml", "price": 66.89 }, { "product_id": "p2", "name": "Fond de ten infuzat cu acid hialuronic care se adaptează la nuanță 30ml", "price": 58.0 }],
        "rows": [{ "label": "Preț", "values": ["66.89 lei", "58.00 lei"] }]
